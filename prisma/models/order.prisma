model Order {
    id        Int         @id @default(autoincrement())
    isMember  Boolean
    createdAt DateTime    @default(now())
    items     OrderItem[]
}

model OrderItem {
    id        Int     @id @default(autoincrement())
    quantity  Int
    name      String
    price     Float
    orderId   Int
    productId Int
    order     Order   @relation(fields: [orderId], references: [id])
    product   Product @relation(fields: [productId], references: [id])
}
